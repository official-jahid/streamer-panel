{% macro Sniper(args) %}
    <script src="{{url_for('static',filename='js/sniper.js')}}"></script>
    <div id="sniper" class="divide-y">
        <div class="p-4 w-full h-full">
            <div class="flex flex-row justify-between items-center h-full">
                <div>
                    <h2 class="text-red-400 font-bold text-2xl neon-blood">Sniper Scope</h2>
                    <span class="text-red-300 opacity-60">Apply One Time In Login</span>
                </div>
                <div class="flex flex-wrap justify-end gap-2">
                    <button id="swEnable" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Enable</button>
                    <button id="swDisable" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Disable</button>
                </div>
            </div>
        </div>
        <div class="p-4 w-full h-full">
            <div class="flex flex-row justify-between items-center h-full">
                <div>
                    <h2 class="text-red-400 font-bold text-2xl neon-blood">Sniper Switch</h2>
                    <span class="text-red-300 opacity-60">Apply One Time In Login</span>
                </div>
                <div class="flex flex-wrap justify-end gap-2 w-fit">
                    <button id="ssEnable" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Enable</button>
                    <button id="ssDisable" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Disable</button>
                </div>
            </div>
        </div>
    </div>
    <style>
        #sniper {
            width: 100%;
            height: min-content;
            border-radius: 10px;
            background: linear-gradient(145deg, rgba(22, 0, 0, 0.9), rgba(75, 0, 0, 0.5));
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            gap: 2rem;
            padding-bottom: 1rem;
            margin-bottom: 60px;
            border: 1px solid rgba(139, 0, 0, 0.3);
            transition: all 0.3s ease;
        }
        #sniper:hover {
            box-shadow: 0 0 20px #8B0000;
        }
    </style>
{% endmacro %}