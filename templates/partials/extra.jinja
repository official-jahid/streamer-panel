{% macro Extra(args) %}
    <script src="{{url_for('static',filename='js/extra.js')}}"></script>
    <div id="extra" class="divide-y">
        <div class="p-4 w-full h-full">
            <div class="flex flex-row justify-between items-center h-full">
                <div>
                    <h2 class="text-red-400 font-bold text-2xl neon-blood">Chams Menu</h2>
                    <span class="text-red-300 opacity-60">Apply Once. [INSERT]</span>
                </div>
                <div>
                    <button id="chamsmenu" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Load</button>
                </div>
            </div>
        </div>
        <div class="p-4 w-full h-full">
            <div class="flex flex-row justify-between items-center h-full">
                <div>
                    <h2 class="text-red-400 font-bold text-2xl neon-blood">Chams 3D</h2>
                    <span class="text-red-300 opacity-60">Apply Once In Game</span>
                </div>
                <div>
                    <button id="chams3d" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Load</button>
                </div>
            </div>
        </div>
        <div class="p-4 w-full h-full">
            <div class="flex flex-row justify-between items-center h-full">
                <div>
                    <h2 class="text-red-400 font-bold text-2xl neon-blood">M82B ESP</h2>
                    <span class="text-red-300 opacity-60">Apply in Login</span>
                </div>
                <div class="flex flex-wrap justify-end gap-2">
                    <button id="mbEnable" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Enable</button>
                    <button id="mbDisable" class="button-blood blood-border text-white p-2 w-24 rounded-md hover-blood-glow transform transition-all duration-300">Disable</button>
                </div>
            </div>
        </div>
    </div>
    <style>
        #extra {
            width: 100%;
            height: min-content;
            border-radius: 10px;
            background: linear-gradient(145deg, rgba(22, 0, 0, 0.9), rgba(75, 0, 0, 0.5));
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            gap: 2rem;
            padding-bottom: 1rem;
            margin-bottom: 60px;
            border: 1px solid rgba(139, 0, 0, 0.3);
            transition: all 0.3s ease;
        }
        #extra:hover {
            box-shadow: 0 0 20px #8B0000;
        }
    </style>
{% endmacro %}