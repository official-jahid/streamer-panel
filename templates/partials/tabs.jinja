{% macro Tabs(num) %}
    <div id="tabs" class="no-scrollbar h-30 card-blood">
        <div class="">
            {% if num ==1 %}
                <a href="/dashboard" class="active button-blood">Headshot</a>
            {% else %}
                <a href="/dashboard" class="inactive hover-blood-glow">Headshot</a>
            {% endif %}
            {% if num ==2 %}
                <a href="/sniper-panel" class="active button-blood">Sniper</a>
            {% else %}
                <a href="/sniper-panel" class="inactive hover-blood-glow">Sniper</a>
            {% endif %}
            {% if num ==3 %}
                <a href="/extra-panel" class="active button-blood">Extra</a>
            {% else %}
                <a href="/extra-panel" class="inactive hover-blood-glow">Extra</a>
            {% endif %}
            {% if num ==4 %}
                <a href="/settings" class="active button-blood">Settings</a>
            {% else %}
                <a href="/settings" class="inactive hover-blood-glow">Settings</a>
            {% endif %}
        </div>
    </div>
    <style>
        #tabs {
	 width: 100%;
	 border-radius: 10px;
	 display: flex;
	 align-items: center;
	 color: white;
	 transition: all 0.3s ease;
}
 #tabs:hover {
	 box-shadow: 0 0 15px #8B0000;
}
 #tabs div {
	 display: flex;
	 width: 100%;
	 height: 100%;
	 overflow-x: scroll;
	 align-items: center;
	 justify-content: space-between;
	 gap: 1rem;
	 padding: 1rem;
}
 #tabs div .button {
	 color: white;
}
.active {
	 color: white;
	 background: linear-gradient(45deg, #8B0000, #DC143C);
	 padding: 1rem;
	 border-radius: 10px;
	 font-weight: 600;
	 height: 50px;
	 display: flex;
	 align-items: center;
	 box-shadow: 0 0 10px #FF0000;
}
.inactive {
	 background: rgba(22, 0, 0, 0.3);
	 padding: 1rem;
	 border-radius: 10px;
	 font-weight: 600;
	 color: #FF6B6B;
	 height: 50px;
	 display: flex;
	 align-items: center;
	 border: 1px solid #8B0000;
}
    </style>
{% endmacro %}